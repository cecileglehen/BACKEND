# ════════════════════════════════════════════════════════════════════
#  DELT AI / Launch — Apache (Hostinger)
#  À déployer dans public_html (deltai.fr) ET dans le dossier du
#  sous-domaine launch.deltai.fr (Vite copie public/ → dist/).
# ════════════════════════════════════════════════════════════════════

RewriteEngine On
RewriteBase /

# ─── Forcer HTTPS (contexte sécurisé requis par WebContainers / Launch) ───
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Isolation cross-origin UNIQUEMENT sur launch.* (preview WebContainer) ───
# Sans ces 2 headers, la preview live de Launch ne démarre PAS en prod.
<IfModule mod_headers.c>
  SetEnvIf Host "^launch\." IS_LAUNCH
  Header set Cross-Origin-Opener-Policy "same-origin" env=IS_LAUNCH
  Header set Cross-Origin-Embedder-Policy "credentialless" env=IS_LAUNCH
</IfModule>

# ─── SPA fallback — routes inconnues → index.html (React Router, /p/<slug>) ───
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ index.html [L]

# ─── Cache long pour les assets versionnés ───
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ─── Compression ───
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ─── Sécurité ───
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ════════════════════════════════════════════════════════════════════
#  RAPPEL — l'API et les sites déployés sont sur le BACKEND Render :
#   • /api/*  → le client appelle https://deltai-backend.onrender.com
#               (VITE_API_BASE) en absolu. Rien à proxifier ici.
#   • /sites/<slug> (apps déployées) → servies par Render, pas par Hostinger.
#     Les liens publics doivent pointer vers le backend (ou un sous-domaine
#     sites.deltai.fr en CNAME vers Render), pas vers deltai.fr/sites/...
# ════════════════════════════════════════════════════════════════════
