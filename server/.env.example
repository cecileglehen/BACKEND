# === API IA ===
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# === Base de données PostgreSQL ===
# Supabase pooler session mode:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/deltai

# === Auth JWT (génère avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ===
JWT_SECRET=change_me_with_a_long_random_string

# === PayPal ===
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# IDs des Billing Plans créés dans le dashboard PayPal
PAYPAL_PLAN_LITE=P-XXXX
PAYPAL_PLAN_PLUS=P-XXXX
PAYPAL_PLAN_PRO=P-XXXX
PAYPAL_PLAN_ULTRA=P-XXXX

# === Serveur ===
PORT=3001
NODE_ENV=production
