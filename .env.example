# Clés API - À copier dans server/.env
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Optionnel - pour la section Artiste si activée
# RECRAFT_API_KEY=
# GOOGLE_API_KEY=

# Crédits initiaux (par défaut 1000)
INITIAL_CREDITS=1000

# Port serveur (défaut 3001)
PORT=3001
